{
  "name": "devstash",
  "version": "0.1.0",
  "description": "Developer productivity toolkit — backup, restore, and automate your dev workflow. Never lose your setup again.",
  "type": "module",
  "bin": {
    "devstash": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean --external better-sqlite3",
    "dev": "tsup src/cli.ts --format esm --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "developer-tools",
    "productivity",
    "cli",
    "terminal-history",
    "workflow",
    "backup",
    "devops",
    "automation"
  ],
  "author": "divyamohan1993",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "public"
  ],
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
